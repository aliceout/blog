---
import BaseLayout from "../layouts/BaseLayout.astro";
import AppShell from "../components/AppShell.astro";
import site from "../data/site.json";
---

<BaseLayout title="À propos" path="/a-propos/">
  <AppShell>
    <div
      class="px-6 sm:px-10 lg:px-16 pt-10 lg:pt-[46px] pb-16 max-w-[760px]"
      style="--hue:150"
    >
      <h1
        class="font-tight text-[34px] sm:text-[38px] font-semibold tracking-[-0.03em] leading-[1.12] mb-[24px]"
      >
        À propos
      </h1>
      <div class="prose">
        <p>
          <strong>{site.name}</strong>, ce sont {site.tagline}
        </p>
        <p>
          J'y note ce que j'ai envie de partager, ce que j'ai trouvé
          d'intéressant. Rien de prétentieux — juste des notes que j'aurais aimé
          lire ailleurs.
        </p>
        <p>
          Le code de ce blog est ouvert sur <a href={site.githubUrl}>GitHub</a
          >.<br />
          Une remarque, une coquille ? <a href={site.mailUrl}>Écris-moi</a>.
        </p>
      </div>
    </div>
  </AppShell>
</BaseLayout>
