---
import BaseLayout from "../layouts/BaseLayout.astro";
import AppShell from "../components/AppShell.astro";
import { getSortedPosts, formatDateShort } from "../utils/posts.js";
import { CATEGORIES } from "../utils/categories.js";

const posts = await getSortedPosts();
const groups = Object.entries(CATEGORIES)
  .map(([key, cat]) => ({
    key,
    ...cat,
    posts: posts.filter((p) => p.data.category === key),
  }))
  .filter((g) => g.posts.length > 0);
---

<BaseLayout title="Catégories" path="/categories/">
  <AppShell>
    <div class="px-6 sm:px-10 lg:px-14 pt-10 lg:pt-[46px] pb-16 max-w-[880px]">
      <h1 class="text-[15px] font-semibold tracking-[-0.01em]">Catégories</h1>

      <div class="mt-[34px] flex flex-col gap-[40px]">
        {
          groups.map((g) => (
            <section style={`--hue:${g.hue}`}>
              <div class="flex items-baseline justify-between border-b border-line pb-[10px]">
                <h2 class="blog-cat-text font-mono text-[14px] tracking-[0.02em]">
                  {g.label}
                </h2>
                <span class="font-mono text-[11.5px] text-ink-3">
                  {g.posts.length} billet{g.posts.length > 1 ? "s" : ""}
                </span>
              </div>
              <ul class="mt-[14px] flex flex-col gap-[12px]">
                {g.posts.map((p) => (
                  <li class="flex items-baseline justify-between gap-4">
                    <a
                      href={`/billets/${p.id}/`}
                      class="text-[15px] text-ink hover:text-[color:var(--color-cat)] transition-colors no-underline"
                    >
                      {p.data.title}
                    </a>
                    <span class="font-mono text-[11.5px] text-ink-3 shrink-0">
                      {formatDateShort(p.data.date)}
                    </span>
                  </li>
                ))}
              </ul>
            </section>
          ))
        }
      </div>
    </div>
  </AppShell>
</BaseLayout>
