---
import BaseLayout from "./BaseLayout.astro";
import AppShell from "../components/AppShell.astro";
import { getCategory } from "../utils/categories.js";
import { formatDate, readingTime } from "../utils/posts.js";

interface Props {
  post: any;
  prev?: any;
  next?: any;
}

const { post, prev = null, next = null } = Astro.props;
const cat = getCategory(post.data.category);
const rt = readingTime(post.body);
const tags = post.data.tags || [];
---

<BaseLayout
  title={post.data.title}
  description={post.data.excerpt}
  path={`/billets/${post.id}/`}
  ogType="article"
>
  <AppShell>
    <article
      class="px-6 sm:px-10 lg:px-16 pt-10 lg:pt-[46px] pb-16 max-w-[760px]"
      style={`--hue:${cat.hue}`}
    >
      <a href="/" class="blog-back">
        <svg
          width="13"
          height="13"
          viewBox="0 0 13 13"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"
          stroke-linejoin="round"><path d="M8 2.5L4 6.5l4 4"></path></svg
        >
        tous les billets
      </a>

      <header class="mt-[30px] mb-[34px]">
        <span class="blog-cat-pill">{cat.label}</span>
        <h1
          class="font-tight text-[34px] sm:text-[38px] font-semibold tracking-[-0.03em] leading-[1.12] mt-[18px] mb-[16px]"
        >
          {post.data.title}
        </h1>
        <div
          class="font-mono text-[12px] text-ink-3 flex flex-wrap items-center gap-[10px]"
        >
          <span>{formatDate(post.data.date)}</span>
          <span class="w-[3px] h-[3px] rounded-full bg-current"></span>
          <span>{rt} de lecture</span>
          {
            post.data.updated && (
              <>
                <span class="w-[3px] h-[3px] rounded-full bg-current" />
                <span>maj. {formatDate(post.data.updated)}</span>
              </>
            )
          }
        </div>
      </header>

      <div class="prose">
        <slot />
      </div>

      <footer class="mt-[44px] pt-[28px] border-t border-line">
        {
          tags.length > 0 && (
            <div class="flex flex-wrap gap-[9px]">
              {tags.map((tag: string) => (
                <a href={`/categories/`} class="blog-tag">
                  #{tag}
                </a>
              ))}
            </div>
          )
        }
        {
          (prev || next) && (
            <div class="flex justify-between gap-[18px] mt-[26px]">
              {prev ? (
                <a href={`/billets/${prev.id}/`} class="blog-nav-link max-w-[46%] no-underline" style="border:0;padding:0">
                  <span class="block font-mono text-[11px] text-ink-3 mb-[5px]">
                    ← précédent
                  </span>
                  <span class="blog-nav-ttl block text-[14.5px] font-medium text-ink-2 leading-[1.3]">
                    {prev.data.title}
                  </span>
                </a>
              ) : (
                <span />
              )}
              {next && (
                <a
                  href={`/billets/${next.id}/`}
                  class="blog-nav-link max-w-[46%] no-underline text-right"
                  style="border:0;padding:0"
                >
                  <span class="block font-mono text-[11px] text-ink-3 mb-[5px]">
                    suivant →
                  </span>
                  <span class="blog-nav-ttl block text-[14.5px] font-medium text-ink-2 leading-[1.3]">
                    {next.data.title}
                  </span>
                </a>
              )}
            </div>
          )
        }
      </footer>
    </article>
  </AppShell>
</BaseLayout>
