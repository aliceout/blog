---
import BaseLayout from "../layouts/BaseLayout.astro";
import AppShell from "../components/AppShell.astro";
import PostRow from "../components/PostRow.astro";
import { getSortedPosts } from "../utils/posts.js";

const posts = await getSortedPosts();
---

<BaseLayout path="/">
  <AppShell>
    <div class="px-6 sm:px-10 lg:px-14 pt-10 lg:pt-[46px] pb-16 max-w-[880px]">
      <div class="flex items-baseline justify-between">
        <h1 class="text-[15px] font-semibold tracking-[-0.01em]">
          Derniers billets
        </h1>
        <span class="font-mono text-[12px] text-ink-3">
          {posts.length} article{posts.length > 1 ? "s" : ""}
        </span>
      </div>
      <div class="mt-[30px]">
        {posts.map((post) => <PostRow post={post} />)}
      </div>
    </div>
  </AppShell>
</BaseLayout>
